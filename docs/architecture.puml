@startuml WanderAI_Component_Architecture
title WanderAI — System Architecture

skinparam backgroundColor #0d1117
skinparam defaultFontColor #c9d1d9
skinparam defaultFontSize 11
skinparam defaultFontName "Helvetica"
skinparam ArrowColor #58a6ff
skinparam ArrowThickness 1.5
skinparam roundcorner 8
skinparam shadowing false

skinparam package {
  BackgroundColor #161b22
  BorderColor #30363d
  FontColor #79c0ff
  FontStyle bold
}

skinparam component {
  BackgroundColor #21262d
  BorderColor #388bfd
  FontColor #c9d1d9
}

skinparam database {
  BackgroundColor #21262d
  BorderColor #3fb950
  FontColor #c9d1d9
}

skinparam note {
  BackgroundColor #161b22
  BorderColor #30363d
  FontColor #8b949e
}

' ════════════════════════════════════════
' USER
' ════════════════════════════════════════
actor "User" as User #c9d1d9

' ════════════════════════════════════════
' FRONTEND
' ════════════════════════════════════════
package "Frontend  ·  React + Tailwind CSS" {
  [Chat Panel\n──────────\nStreaming message UI\nSession state] as ChatUI
  [Plan Panel\n──────────\nItinerary cards\nVenue + social links] as PlanUI
  [Mapbox GL JS\n──────────\nNumbered markers\nDashed route line\nVenue popups] as MapUI
}

' ════════════════════════════════════════
' BACKEND
' ════════════════════════════════════════
package "Backend  ·  Python FastAPI" {
  [POST /api/chat\n──────────\nManage session\nStream SSE response] as ChatAPI
  [POST /api/plan\n──────────\nTrigger plan generation\nReturn structured JSON] as PlanAPI
}

' ════════════════════════════════════════
' AGENT LAYER
' ════════════════════════════════════════
package "Agent Layer  ·  LangChain + Claude Sonnet" {
  [Conversational Agent\n──────────\nOnboarding Q&A\nBuild preference brief] as ConvAgent
  [Plan Generator Agent\n──────────\nMulti-stop itinerary\nVenue selection + ordering] as PlanAgent
  [Tool: vector_search\n──────────\nEmbed query → k-NN\nReturn top venues] as VectorTool
  [Tool: maps_enrich\n──────────\nFetch hours, address\nrating, price level] as MapsTool
  [Tool: format_plan\n──────────\nStructured JSON output\nwith Pydantic schema] as FormatTool
}

' ════════════════════════════════════════
' EXTERNAL APIs
' ════════════════════════════════════════
package "External APIs" {
  [Claude API\n──────────\nclaude-sonnet-4-6\nTool use + streaming] as ClaudeAPI
  [Google Maps\nPlaces API\n──────────\nPlace details lookup] as GMapsAPI
  [Mapbox API\n──────────\nTiles, Geocoding\nDirections] as MapboxAPI
}

' ════════════════════════════════════════
' DATA LAYER
' ════════════════════════════════════════
package "Data Layer" {
  database "ChromaDB\n──────────\nVenue embeddings\n+ social metadata" as VectorDB
}

' ════════════════════════════════════════
' DATA PIPELINE (OFFLINE)
' ════════════════════════════════════════
package "Data Pipeline  ·  Offline / Pre-Demo" {
  [Apify Scrapers\n──────────\nTikTok · Instagram\nYouTube actors] as Scrapers
  [Data Enricher\n──────────\nMaps API lookup\nMerge social + ops data] as Enricher
  [Sentence Transformer\n──────────\nall-MiniLM-L6-v2\nGenerate embeddings] as Embedder
  Scrapers -down-> Enricher : raw social\ndata (JSON)
  Enricher -down-> Embedder : enriched\nvenue records
  Embedder -down-> VectorDB : upsert\n(embedding + metadata)
}

' ════════════════════════════════════════
' CONNECTIONS — User ↔ Frontend
' ════════════════════════════════════════
User -right-> ChatUI : type message
ChatUI -down-> PlanUI : plan received
ChatUI -right-> MapUI : venues for map

' ════════════════════════════════════════
' CONNECTIONS — Frontend ↔ Backend
' ════════════════════════════════════════
ChatUI -down-> ChatAPI : POST /api/chat\n{message, session_id}
PlanUI -down-> PlanAPI : POST /api/plan\n{preferences}
MapUI -right-> MapboxAPI : tiles / geocode\nHTTPS

' ════════════════════════════════════════
' CONNECTIONS — Backend ↔ Agent
' ════════════════════════════════════════
ChatAPI -down-> ConvAgent : invoke(message,\nhistory)
PlanAPI -down-> PlanAgent : invoke(preference_brief)

' ════════════════════════════════════════
' CONNECTIONS — Agent ↔ LLM + Tools
' ════════════════════════════════════════
ConvAgent -right-> ClaudeAPI : LLM call\n(tool use)
PlanAgent -right-> ClaudeAPI : LLM call\n(tool use)

ConvAgent -down-> VectorTool : tool call
PlanAgent -down-> VectorTool : tool call
PlanAgent -down-> MapsTool : tool call
PlanAgent -down-> FormatTool : tool call

VectorTool -down-> VectorDB : similarity_search\n(embedding, k=20)
MapsTool -right-> GMapsAPI : place_details\n(name, city)

' ════════════════════════════════════════
' RETURN FLOWS (dashed)
' ════════════════════════════════════════
ConvAgent ..> ChatAPI : SSE stream\n(text chunks)
ChatAPI ..> ChatUI : Server-Sent Events
PlanAgent ..> PlanAPI : plan JSON\n(Pydantic model)
PlanAPI ..> PlanUI : itinerary\n+ venue list

note bottom of VectorDB
  Each record stores:
  • venue_name, city, category
  • description (from social)
  • source_url (TikTok/IG/YT)
  • view_count, engagement
  • lat, lng
  • hours, phone, price_level
  • embedding vector (384-dim)
end note

note bottom of ClaudeAPI
  System prompt defines:
  • Agent persona (WanderAI)
  • Tool schemas
  • Output format rules
  • City/venue guardrails
end note

@enduml
