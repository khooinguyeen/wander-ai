# ── Claude / Anthropic ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Maps ─────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza...

# ── Mapbox (used by frontend) ───────────────────────────────────────────────
MAPBOX_TOKEN=pk.eyJ1...

# ── Apify ────────────────────────────────────────────────────────────────────
APIFY_API_TOKEN=apify_api_...

# ── ChromaDB ─────────────────────────────────────────────────────────────────
# Leave blank to use embedded (local) ChromaDB
CHROMA_HOST=
CHROMA_PORT=8001
CHROMA_COLLECTION=wander_venues

# ── Backend ──────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173

# ── Feature flags ────────────────────────────────────────────────────────────
# Set to "true" to use mock tools (no ChromaDB / Maps API needed)
USE_MOCK_TOOLS=false
